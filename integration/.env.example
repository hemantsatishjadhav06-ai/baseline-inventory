# ── Baseline ↔ Magento integration ──────────────────────────────
# Copy to .env and fill in. NEVER commit .env. In production, load
# MAGENTO_ACCESS_TOKEN from a secret store, not a file.

# Magento store (Tennis Outlet)
MAGENTO_BASE_URL=https://console.tennisoutlet.in
MAGENTO_API_PREFIX=/rest/V1

# ⚠️ SECRET — Integration access token (Admin → System → Integrations).
# The token shared during design should be ROTATED before go-live and
# the new value placed here / in your secret store.
MAGENTO_ACCESS_TOKEN=__set_in_secret_store__

# If Multi-Source Inventory (MSI) is enabled, set the stock id (usually 1)
MAGENTO_STOCK_ID=1

# Pull tuning
MAGENTO_RATE_LIMIT_RPS=4
MAGENTO_PAGE_SIZE=100
SYNC_CRON=*/15 * * * *        # stock + orders every 15 min
SYNC_FULL_CRON=0 2 * * *      # full catalog reconcile nightly at 02:00

# Baseline datastore
DATABASE_URL=postgres://baseline:baseline@localhost:5432/baseline
REDIS_URL=redis://localhost:6379

# Engine defaults (per-SKU overrides live in the supplier table)
ENGINE_SAFETY_FACTOR=0.5      # safety stock = avgDaily * leadTime * factor
ENGINE_REVIEW_PERIOD_DAYS=15
ENGINE_TARGET_MAX_DAYS=60
ENGINE_DEAD_AFTER_DAYS=90
